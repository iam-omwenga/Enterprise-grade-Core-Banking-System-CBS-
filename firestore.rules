rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isStaff() {
      return isSignedIn() && getUserData().role != 'CUSTOMER';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'fullName', 'role', 'kycStatus', 'createdAt', 'updatedAt']) &&
               data.uid == request.auth.uid &&
               data.email == request.auth.token.email &&
               data.role is string &&
               data.kycStatus in ['PENDING', 'VERIFIED', 'REJECTED'];
      }

      allow get: if isSignedIn() && (request.auth.uid == userId || isStaff());
      allow list: if isStaff();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phoneNumber', 'updatedAt']);
      allow update: if isStaff() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'kycStatus', 'updatedAt']);
    }

    // Account Rules
    match /accounts/{accountId} {
      function isValidAccount(data) {
        return data.keys().hasAll(['accountNumber', 'customerId', 'type', 'balance', 'currency', 'status', 'createdAt', 'updatedAt']) &&
               data.balance is number &&
               data.status in ['ACTIVE', 'FROZEN', 'CLOSED'];
      }

      allow get: if isSignedIn() && (getUserData().uid == existing().customerId || isStaff());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow create: if isStaff() && isValidAccount(incoming());
      allow update: if isStaff() && isValidAccount(incoming());
    }

    // Transaction Rules (Sub-collection)
    match /accounts/{accountId}/transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.keys().hasAll(['accountId', 'type', 'amount', 'status', 'description', 'reference', 'performedBy', 'createdAt', 'updatedAt']) &&
               data.accountId == accountId &&
               data.amount is number;
      }

      allow read: if isSignedIn() && (get(/databases/$(database)/documents/accounts/$(accountId)).data.customerId == request.auth.uid || isStaff());
      allow create: if isStaff() && isValidTransaction(incoming());
    }

    // Loan Rules
    match /loans/{loanId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || isStaff());
      allow create: if isSignedIn() && (request.auth.uid == incoming().customerId || isStaff());
      allow update: if isStaff();
    }
  }
}
